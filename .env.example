# Copy to .env and fill in real values. Never commit .env.
#
# This file is used by docker-compose for local development.
# For production, set these as secrets/env vars in Azure Container Apps
# and Cloudflare Pages — never pass them through a committed file.

# ── agent-api ────────────────────────────────────────────────────────────────

# Anthropic API key for the Ask Tal agent.
# Get one at https://console.anthropic.com
# Leave blank to run the rest of the stack without the agent (/health will
# report agent_available: false and /chat will return 503).
ANTHROPIC_API_KEY=

# ── All three services ────────────────────────────────────────────────────────

# Comma-separated list of origins the browser is allowed to call from.
# In production this must be your Cloudflare Pages URL, e.g.:
#   ALLOWED_ORIGINS=https://portfolio.example.com
# docker-compose hardcodes http://localhost:5173 for each service and does
# not read this variable — only set it here if running a service directly
# (e.g. `uvicorn app.main:app`) outside of docker-compose.
ALLOWED_ORIGINS=http://localhost:5173

# ── agent-api: upstream service URLs ─────────────────────────────────────────

# Base URLs the agent uses to call the data services.
# docker-compose sets these via service DNS; uncomment only if running
# agent-api standalone (outside docker-compose).
# EXPERIENCE_API_URL=http://localhost:5001
# PERSONA_API_URL=http://localhost:5002

# Base URL for CV download links returned to the browser.
# Set to your production domain once deployed.
# SITE_BASE_URL=http://localhost:5173

# ── web frontend (Vite build-time) ───────────────────────────────────────────

# These are baked into the Vite bundle at build time — they are not secrets.
# docker-compose sets them automatically for local dev.
#
# For Cloudflare Pages: add these as environment variables in the Pages
# dashboard under Settings → Environment variables (Production & Preview).
#
# For local development outside docker-compose, copy these into web/.env.local:
# VITE_EXPERIENCE_API=http://localhost:5001
# VITE_PERSONA_API=http://localhost:5002
# VITE_AGENT_API=http://localhost:5003
